{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/batch-resume-hook.mjs"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/lock-release-hook.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/dashboard-reminder-hook.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/dashboard-guard.mjs"
          },
          {
            "type": "command",
            "command": "node scripts/prep-guard.mjs"
          },
          {
            "type": "command",
            "command": "node scripts/batch-progress-guard.mjs"
          },
          {
            "type": "command",
            "command": "node scripts/render-verify-guard.mjs"
          },
          {
            "type": "command",
            "command": "node scripts/queue-order-guard.mjs"
          },
          {
            "type": "command",
            "command": "node scripts/dashboard-integrity-guard.mjs"
          },
          {
            "type": "command",
            "command": "node scripts/ci-status-guard.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/worktree-reminder.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/prep-arm-hook.mjs"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/lock-heartbeat-hook.mjs"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Skill",
      "Agent",
      "NotebookEdit",
      "TodoWrite",
      "PowerShell",
      "ToolSearch",
      "Workflow",
      "Monitor",
      "TaskOutput",
      "TaskStop",
      "SendMessage",
      "CronCreate",
      "CronDelete",
      "CronList",
      "EnterWorktree",
      "ExitWorktree",
      "DesignSync",
      "PushNotification",
      "RemoteTrigger",
      "ScheduleWakeup",
      "ReportFindings",
      "Artifact",
      "AskUserQuestion",
      "EnterPlanMode",
      "ExitPlanMode"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "defaultMode": "dontAsk",
    "additionalDirectories": []
  }
}
